# Clean URLs: hide .html and .php from the address bar.
RewriteEngine On

# /index.(html|php) and /dir/index.(html|php)  ->  /  and  /dir/   (301)
RewriteCond %{THE_REQUEST} \s/+([^?\s]*/)?index\.(html|php)[\s?] [NC]
RewriteRule ^([^?]*/)?index\.(html|php)$ /%1 [R=301,L]

# /page.(html|php)  ->  /page   (301)
RewriteCond %{THE_REQUEST} \s/+([^?\s]+)\.(html|php)[\s?] [NC]
RewriteRule ^([^?]+)\.(html|php)$ /$1 [R=301,L]

# Internally serve /page from /page.php first (no redirect)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1.php -f
RewriteRule ^(.+?)/?$ $1.php [L]

# then fall back to /page.html (no redirect)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
